  "10-37": (
    caption: [A scanning electron micrograph of human red blood cells. The cells have a biconcave shape and lack a nucleus and other organelles (Movie 10.7). (Courtesy of Bernadette Chailley.) 5 µm],
    path: "../fig/image_place_holder.png"
