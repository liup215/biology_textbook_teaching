  "21-60": (
    caption: [Members of the same species can have dramatically different sizes. The Chihuahua weighs 2–5 kg, whereas a Great Dane weighs 45–90 kg. (Courtesy of Deanne Fitzmaurice.)],
    path: "../fig/image_place_holder.png"
