#let images = (
  "12-1": (
    caption: [The major intracellular compartments of an animal cell. The cytosol (gray), rough endoplasmic reticulum, smooth endoplasmic reticulum, Golgi apparatus, nucleus, mitochondrion, endosome, lysosome, and peroxisome are distinct compartments isolated from the rest of the cell by at least one selectively permeable membrane (see Movie 9.2). By contrast, the nucleolus is not enclosed by a membrane and represents one example of a biomolecular condensate.],
    path: "../fig/image_place_holder.png"
