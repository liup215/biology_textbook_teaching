#let images = (
  "figure-8.1": (
    caption: [
      Diagram of four primary mating-system categories: (A) *monogamy* (1 male, 1 female), (B) *polygyny* (1 male, multiple females), (C) *polyandry* (1 female, multiple males), and (D) *polygynandry* (multiple males, multiple females). Use this figure to map mating-system terminology to the number of mating partners and to illustrate that each system has subtypes and ecological variants.
    ],
    path: "../fig/fig-2025-11-05-20-08-49.png"
  ),

  "figure-8.2": (
    caption: [
      Photo and summary of long-term monogamy in the oldfield mouse (Peromyscus polionotus). Key result: genetic and behavioral data indicate ~90 percent paternity by the resident male, supporting long-term pair bonds and illustrating *monogamy* tied to small mammal ecology.
    ],
    path: "../fig/fig-2025-11-05-20-09-05.png"
  ),

  "figure-8.3": (
    caption: [
      Bar summary showing paternity distribution in oldfield mouse burrows: the resident male sires ~90 percent of pups. Use this to support how field genetic sampling reveals social versus genetic mating outcomes.
    ],
    path: "../fig/fig-2025-11-05-20-15-17.png"
  ),

  "table-8.1": (
    caption: [
      Table mapping mating combinations to expected mating success for males and females (polyandry, monogamy, polygynandry, polygyny). Use this table to compare how each mating combination changes male versus female access to mates and expected reproductive payoffs.
