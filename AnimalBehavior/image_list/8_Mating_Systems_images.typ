    path: "../fig/fig-2025-11-05-20-15-46.png"
  ),

  "figure-8.4": (
    caption: [
      Two-panel experimental result (Ryan & Altmann) showing fitness consequences of male choice in monogamous systems. Panel A: males paired with preferred females produced more surviving pups. Panel B: when preferred females were given to naive males, benefits disappeared, indicating *individual-specific* mate compatibility or behavioural effects. Use this to illustrate mate choice consequences on offspring survival.
    ],
    path: "../fig/fig-2025-11-05-20-16-24.png"
  ),

  "figure-8.5": (
    caption: [
      Graph illustrating variance in reproductive success under polygyny: while average reproductive success equals across sexes, *variance* is higher in the sex with multiple mates (typically males). Use to explain why sexual selection intensity differs between sexes.
    ],
    path: "../fig/fig-2025-11-05-20-19-25.png"
  ),

  "figure-8.6": (
    caption: [
