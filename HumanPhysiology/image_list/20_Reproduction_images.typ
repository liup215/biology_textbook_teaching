#let images = (
  "20-1": (
    caption: [The human life cycle showing the progression from gametes (haploid, 23 chromosomes) through fertilization to zygote (diploid, 46 chromosomes), and development through meiosis back to gametes. This illustrates sexual reproduction and chromosome number changes.],
    path: "../fig/image_place_holder.png"
  ),
  "20-2": (
    caption: [The human X and Y chromosomes magnified about 10,000×, revealing dramatic differences in size and shape. The Y chromosome appears smaller and simpler than the X chromosome, yet contains critical genes for male sex determination.],
    path: "../fig/image_place_holder.png"
  ),
  "20-3": (
    caption: [Barr bodies in cheek cell nuclei. Female cells (a) contain Barr bodies (arrow), formed from one inactive X chromosome. Male cells lack Barr bodies, demonstrating X-inactivation in females for dosage compensation.],
    path: "../fig/image_place_holder.png"
  ),
  "20-4": (
    caption: [The chromosomal sex and development of embryonic gonads. Early embryos have indifferent gonads that can become either testes or ovaries. The testis-determining factor (TDF) gene on the Y chromosome directs testis development.],
    path: "../fig/image_place_holder.png"
  ),
  "20-5": (
    caption: [The regulation of embryonic sexual development. When testosterone and müllerian inhibition factor (MIF) are secreted by testes, male external genitalia and accessory sex organs develop. Without these secretions, female structures develop by default.],
    path: "../fig/image_place_holder.png"
  ),
  "20-6": (
    caption: [The development of external genitalia in male and female. Shows the differentiation process from genital tubercle, urogenital fold, and labioscrotal swelling into distinctly male or female structures by week 12 of development.],
    path: "../fig/image_place_holder.png"
  ),
  "table-20-1": (
