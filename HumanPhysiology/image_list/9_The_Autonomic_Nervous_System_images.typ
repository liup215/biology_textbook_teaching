#let images = (
  "9-1": (
    caption: [The autonomic system has preganglionic and postganglionic neurons. The preganglionic neurons have cell bodies in the CNS (central nervous system), whereas the postganglionic neurons have cell bodies within autonomic ganglia. This two-neuron pathway distinguishes autonomic from somatic motor innervation.],
    path: "../fig/image_place_holder.png"
  ),
  "table-9-1": (
    caption: [Comparison of the Somatic Motor System and the Autonomic Motor System. Key differences include the number of neurons (somatic has one, autonomic has two), presence of ganglia (autonomic has ganglia while somatic does not), effector organs (somatic targets skeletal muscles, autonomic targets cardiac muscle, smooth muscle, and glands), and neurotransmitters used.],
    path: "../fig/image_place_holder.png"
  ),
  "9-2": (
    caption: [The sympathetic chain of paravertebral ganglia showing the anatomical relationship between the sympathetic ganglia and the vertebral column and spinal cord. These paired ganglia run parallel to the spinal cord from cervical to sacral regions, forming the sympathetic chain or trunk.],
    path: "../fig/image_place_holder.png"
  ),
  "9-3": (
    caption: [The pathway of sympathetic neurons. The preganglionic neurons enter the sympathetic chain of ganglia via the white ramus communicans. Some synapse there, with postganglionic axons leaving via the gray ramus to rejoin spinal nerves. Others pass through without synapsing, ultimately synapsing in collateral ganglia such as the celiac ganglion. This illustrates both paravertebral and collateral ganglion pathways.],
    path: "../fig/image_place_holder.png"
  ),
  "9-4": (
    caption: [The collateral sympathetic ganglia including the celiac ganglion and the superior and inferior mesenteric ganglia. These unpaired ganglia are located in the abdominal cavity and receive preganglionic fibers that pass through the sympathetic chain without synapsing, traveling via splanchnic nerves. They innervate digestive and other abdominal organs.],
    path: "../fig/image_place_holder.png"
  ),
  "table-9-2": (
    caption: [The Sympathetic Division showing the origin of preganglionic fibers (thoracolumbar: T1-L2), location of ganglia (paravertebral chain and collateral ganglia), and the organs innervated by each pathway including their physiological effects.],
    path: "../fig/image_place_holder.png"
  ),
  "table-9-3": (
    caption: [The Parasympathetic Division showing the craniosacral origins (cranial nerves III, VII, IX, X and sacral segments S2-S4), associated ganglia (ciliary, pterygopalatine, submandibular, otic, and terminal ganglia), and their target organs with specific physiological effects.],
    path: "../fig/image_place_holder.png"
  ),
  "9-5": (
    caption: [The autonomic nervous system overview. The sympathetic division is shown in red and the parasympathetic in blue. Solid lines indicate preganglionic fibers, and dashed lines indicate postganglionic fibers. This comprehensive diagram shows the dual innervation of most organs and the anatomical organization of both divisions from CNS to effector organs.],
    path: "../fig/image_place_holder.png"
  ),
  "9-6": (
    caption: [The path of the vagus nerves (cranial nerve X). The vagus nerves and their branches provide extensive parasympathetic innervation to most organs within the thoracic and abdominal cavities, including the heart, lungs, esophagus, stomach, liver, pancreas, and intestines. This demonstrates the wide-ranging influence of parasympathetic control.],
    path: "../fig/image_place_holder.png"
  ),
  "table-9-4": (
    caption: [Effects of Autonomic Nerve Stimulation on Various Effector Organs. This comprehensive table shows the antagonistic effects of sympathetic and parasympathetic stimulation on multiple organ systems including the eye, heart, blood vessels, digestive system, respiratory system, and others, demonstrating the principle of dual innervation and complementary regulation.],
    path: "../fig/image_place_holder.png"
  ),
  "9-7": (
    caption: [Neurotransmitters of the autonomic motor system. Shows that acetylcholine (ACh) is released by all preganglionic neurons and by postganglionic parasympathetic neurons (cholinergic). Norepinephrine (NE) is released by postganglionic sympathetic neurons (adrenergic). The adrenal medulla secretes both epinephrine (85%) and norepinephrine (15%) as hormones into the bloodstream.],
    path: "../fig/image_place_holder.png"
  ),
  "9-8": (
    caption: [The catecholamine family of molecules derived from the amino acid tyrosine. The biosynthetic pathway shows the conversion: tyrosine → DOPA → dopamine → norepinephrine → epinephrine. Notice that epinephrine has an additional methyl group compared to norepinephrine. These molecules serve as neurotransmitters (dopamine, norepinephrine) and hormones (epinephrine).],
    path: "../fig/image_place_holder.png"
  ),
  "9-9": (
    caption: [Sympathetic and parasympathetic axons release different neurotransmitters at synapses en passant. (a) Autonomic axons have varicosities (swellings) along their length that contain neurotransmitter vesicles, forming synapses in passing with target cells. (b) Sympathetic axons release norepinephrine which binds to adrenergic receptors, while parasympathetic neurons release acetylcholine which binds to cholinergic receptors, typically producing antagonistic effects on smooth muscles.],
    path: "../fig/image_place_holder.png"
  ),
  "table-9-5": (
    caption: [Selected Adrenergic Effects in Different Organs showing the specific adrenergic receptor subtypes (α₁, α₂, β₁, β₂) in various organs and the physiological responses they mediate. For example, β₂ receptors in bronchioles cause dilation, while α₁ receptors in blood vessels cause constriction, demonstrating receptor-specific effects.],
    path: "../fig/image_place_holder.png"
  ),
  "9-10": (
    caption: [Receptors involved in autonomic regulation. Acetylcholine (ACh) released by all preganglionic neurons stimulates postganglionic neurons via nicotinic ACh receptors (ligand-gated ion channels). Postganglionic parasympathetic axons regulate target organs through muscarinic ACh receptors (G-protein-coupled). Postganglionic sympathetic axons provide adrenergic regulation via α₁, β₁, and β₂ adrenergic receptors (all G-protein-coupled).],
    path: "../fig/image_place_holder.png"
  ),
  "9-11": (
    caption: [Comparison of nicotinic and muscarinic acetylcholine receptors. Nicotinic receptors are ligand-gated ion channels where ACh binding directly opens the channel to allow Na⁺ influx and K⁺ efflux, always producing excitation. Muscarinic ACh receptors are G-protein-coupled receptors where ACh binding activates G-proteins that indirectly open or close ion channels and activate enzymes, producing either excitatory or inhibitory effects depending on the receptor subtype and tissue.],
    path: "../fig/image_place_holder.png"
  ),
  "table-9-6": (
    caption: [Cholinergic Receptors and Responses to Acetylcholine showing nicotinic receptors in skeletal muscle and autonomic ganglia (always excitatory via direct ion channel opening) versus muscarinic receptors in smooth muscle, glands, and heart (can be excitatory or inhibitory via G-protein-coupled mechanisms). This illustrates the diverse effects of ACh depending on receptor type.],
    path: "../fig/image_place_holder.png"
  ),
  "table-9-8": (
    caption: [Effects Resulting from Sensory Input from Afferent Fibers in the Vagus nerve, which mediate visceral reflexes. These afferent fibers carry sensory information from internal organs to the CNS, where they influence autonomic output and contribute to homeostatic regulation through reflex arcs.],
    path: "../fig/image_place_holder.png"
  )
)
