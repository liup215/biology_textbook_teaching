#let images = (
  "12-1": (
    caption: [The structure of a skeletal muscle, showing the hierarchical organization from whole muscle to individual muscle fibers. The relationship between muscle fibers and the connective tissues (tendon, epimysium, perimysium, and endomysium) is illustrated, with a close-up view of a single muscle fiber containing myofibrils, nuclei, and striations.],
    path: "../fig/image_place_holder.png"
  ),
  "12-2": (
    caption: [The appearance of skeletal muscle fibers through the light microscope, showing the characteristic striations produced by alternating dark A bands and light I bands, with nuclei located at the periphery of the muscle fiber.],
    path: "../fig/image_place_holder.png"
  ),
  "12-3": (
    caption: [Motor end plates at the neuromuscular junction, showing the synapse between nerve fiber and muscle fiber. The motor end plate is the specialized portion of the sarcolemma surrounding the axon terminal, with detailed views of the neuromuscular cleft, synaptic vesicles, and folded sarcolemma.],
    path: "../fig/image_place_holder.png"
  ),
  "12-4": (
    caption: [Motor units, consisting of a somatic motor neuron and all the muscle fibers it innervates. The illustration demonstrates how a single motor neuron branches to innervate multiple muscle fibers within a skeletal muscle.],
    path: "../fig/image_place_holder.png"
  ),
  "12-5": (
    caption: [The components of a skeletal muscle fiber, showing how a muscle fiber is composed of numerous myofibrils containing myofilaments of actin and myosin. The overlapping arrangement of myofilaments produces the striated appearance characteristic of skeletal muscle.],
    path: "../fig/image_place_holder.png"
  ),
  "12-6": (
    caption: [The striations of skeletal muscles produced by thick and thin filaments. Electron micrograph and illustration showing the banding pattern (A bands, I bands, H zones, and Z discs) characteristic of striated muscle in longitudinal section.],
    path: "../fig/image_place_holder.png"
  ),
  "12-7": (
    caption: [Arrangement of thick and thin filaments in a striated muscle fiber, demonstrating the three-dimensional structure of sarcomeres. The longitudinal and cross-sectional views reveal the hexagonal arrangement of thin filaments surrounding thick filaments.],
    path: "../fig/image_place_holder.png"
  ),
  "12-8": (
    caption: [Titin filaments and M lines within the sarcomere. M lines are protein filaments in the middle of A bands that anchor thick filaments together. Titin proteins are giant elastic proteins that run through thick filaments from M lines to Z discs, stabilizing thick filament position and providing elastic properties.],
    path: "../fig/image_place_holder.png"
  ),
  "12-9": (
    caption: [The sliding filament model of muscle contraction, showing electron micrograph and diagram of how filaments slide past each other. As contraction progresses, Z lines are brought closer together and sarcomeres shorten, while filament lengths remain constant.],
    path: "../fig/image_place_holder.png"
  ),
  "12-10": (
    caption: [Activation of the myosin head through ATP hydrolysis. The myosin head contains an actin-binding site and an ATP-binding site with ATPase activity. When ATP is hydrolyzed to ADP and Pi, the myosin head becomes activated and changes orientation, ready to bind actin.],
    path: "../fig/image_place_holder.png"
  ),
  "12-11": (
    caption: [The cross-bridge power stroke mechanism. After the activated myosin head binds to actin forming a cross-bridge, release of Pi causes a conformational change in the myosin head, producing the power stroke that moves the actin filament.],
    path: "../fig/image_place_holder.png"
  ),
  "12-12": (
    caption: [The cross-bridge cycle, illustrating the complete sequence of events in muscle contraction. ATP hydrolysis activates the cross-bridge, Pi release produces the power stroke, and binding of new ATP allows cross-bridge detachment from actin.],
    path: "../fig/image_place_holder.png"
  ),
  "12-13": (
    caption: [The structural relationship between troponin, tropomyosin, and actin in thin filaments. Tropomyosin is attached to actin, while the troponin complex (consisting of three subunits) is attached to tropomyosin, regulating access of myosin to actin-binding sites.],
    path: "../fig/image_place_holder.png"
  ),
  "12-14": (
    caption: [The role of calcium ions in muscle contraction. When Ca²⁺ binds to troponin, it causes movement of the troponin-tropomyosin complex, exposing binding sites on actin. This allows myosin cross-bridges to attach and undergo power strokes.],
    path: "../fig/image_place_holder.png"
  ),
  "12-15": (
    caption: [The sarcoplasmic reticulum and its relationship to myofibrils and transverse tubules. The sarcoplasmic reticulum stores Ca²⁺ and releases it when stimulated by action potentials arriving in the transverse tubules (T-tubules).],
    path: "../fig/image_place_holder.png"
  ),
  "12-16": (
    caption: [Excitation-contraction coupling in skeletal muscle. The sequence shows how acetylcholine binding triggers action potentials, which propagate along the sarcolemma and down T-tubules, causing Ca²⁺ release from the sarcoplasmic reticulum to initiate contraction.],
    path: "../fig/image_place_holder.png"
  ),
  "12-17": (
    caption: [Summary of excitation-contraction coupling. Electrical excitation (action potentials conducted along the sarcolemma and down transverse tubules) triggers Ca²⁺ release from the sarcoplasmic reticulum. The Ca²⁺ binding to troponin couples excitation to contraction.],
    path: "../fig/image_place_holder.png"
  ),
  "12-18": (
    caption: [Recording muscle contractions using a myograph. Recorder tracings demonstrate twitch contractions and summation in an isolated frog gastrocnemius muscle, showing the relationship between stimulus and mechanical response.],
    path: "../fig/image_place_holder.png"
  ),
  "12-19": (
    caption: [Incomplete and complete tetanus in muscle contraction. When a muscle is stimulated repeatedly, individual twitches summate. At lower frequencies (5-10 per second), incomplete tetanus with visible separate twitches occurs. At higher frequencies (60 per second), complete tetanus produces smooth, sustained contraction.],
    path: "../fig/image_place_holder.png"
  ),
  "12-20": (
    caption: [Force-velocity curve illustrating the inverse relationship between load and velocity of muscle shortening. As the opposing force increases, shortening velocity decreases. When force is sufficient to prevent shortening, the contraction becomes isometric. Maximum velocity (Vmax) occurs with no opposing load.],
    path: "../fig/image_place_holder.png"
  ),
  "12-21": (
    caption: [The length-tension relationship in skeletal muscles. Maximum tension is achieved when the muscle is at 100-120% of its resting length (sarcomere lengths of 2.0-2.25 μm). Increases or decreases in muscle length result in rapid decreases in tension due to changes in thick-thin filament overlap.],
    path: "../fig/image_place_holder.png"
  ),
  "12-22": (
    caption: [Muscle fuel consumption during exercise at different intensities. The relative contributions of plasma glucose, plasma free fatty acids, muscle glycogen, and muscle triglycerides vary with exercise intensity (mild, moderate, and intense exercise).],
    path: "../fig/image_place_holder.png"
  ),
  "12-23": (
    caption: [Glucose uptake in leg muscle during exercise with a cycle ergometer. Glucose uptake increases with both exercise intensity (measured in Watts) and exercise duration, largely due to increased GLUT4 transporter insertion into the sarcolemma during muscle contraction.],
    path: "../fig/image_place_holder.png"
  ),
  "12-24": (
    caption: [The production and use of phosphocreatine in muscles. Phosphocreatine serves as a rapid reserve of high-energy phosphate for ATP formation. The reactions are catalyzed by creatine phosphokinase (CPK), allowing quick energy availability during intense muscle activity.],
    path: "../fig/image_place_holder.png"
  ),
  "12-25": (
    caption: [Comparison of contraction rates in different muscle types. The fast-twitch extraocular and gastrocnemius muscles develop maximum tension rapidly, while the slow-twitch soleus muscle develops tension more slowly, reflecting differences in fiber type composition.],
    path: "../fig/image_place_holder.png"
  ),
  "12-26": (
    caption: [Relative abundance of different muscle fiber types in different individuals. The percentage distribution of slow type I fibers, fast type IIX fibers, and intermediate fast type IIA fibers varies tremendously among people due to genetic differences and physical training effects.],
    path: "../fig/image_place_holder.png"
  ),
  "12-27": (
    caption: [The location and structure of a muscle spindle within skeletal muscle. Muscle spindles are stretch receptors containing specialized intrafusal muscle fibers with sensory nerve endings that detect changes in muscle length and rate of length change.],
    path: "../fig/image_place_holder.png"
  ),
  "12-28": (
    caption: [The knee-jerk reflex as an example of a monosynaptic stretch reflex. Tapping the patellar tendon stretches the quadriceps muscle, activating muscle spindles that send signals directly to alpha motor neurons, causing immediate muscle contraction.],
    path: "../fig/image_place_holder.png"
  ),
  "12-29": (
    caption: [The action of the Golgi tendon organ in muscle tension regulation. Increased muscle tension stimulates sensory nerve endings in the Golgi tendon organ, which activate inhibitory interneurons that reduce motor neuron activity, preventing excessive muscle force (a disynaptic reflex).],
    path: "../fig/image_place_holder.png"
  ),
  "12-30": (
    caption: [Reciprocal innervation diagram showing how muscle spindle afferents stimulate alpha motor neurons to agonist muscles directly while inhibiting antagonist muscle motor neurons through inhibitory interneurons, ensuring coordinated movement.],
    path: "../fig/image_place_holder.png"
  ),
  "12-31": (
    caption: [The crossed-extensor reflex demonstrating double reciprocal innervation. This complex reflex coordinates withdrawal of a stimulated limb with extension of the opposite limb, involving multiple levels of neural control.],
    path: "../fig/image_place_holder.png"
  ),
  "12-32": (
    caption: [Myocardial cells interconnected by gap junctions. Gap junctions are fluid-filled channels composed of connexin proteins that allow electrical impulse conduction from cell to cell, enabling coordinated cardiac muscle contraction.],
    path: "../fig/image_place_holder.png"
  ),
  "12-33": (
    caption: [Cardiac muscle structure showing short, branched, striated cells interconnected by intercalated discs. These specialized junctions contain gap junctions and desmosomes that provide both electrical and mechanical coupling between cells.],
    path: "../fig/image_place_holder.png"
  ),
  "12-34": (
    caption: [Excitation-contraction coupling in cardiac muscle. Voltage-gated Ca²⁺ channels in T-tubules allow extracellular Ca²⁺ entry, triggering Ca²⁺-induced Ca²⁺ release from the sarcoplasmic reticulum. Ca²⁺ ATPase pumps then actively transport Ca²⁺ back into the sarcoplasmic reticulum for relaxation.],
    path: "../fig/image_place_holder.png"
  ),
  "12-35": (
    caption: [Smooth muscle structure and contractile apparatus. Unlike striated muscle, smooth muscle cells lack organized sarcomeres. Thick and thin filaments are anchored to dense bodies, and myosin is arranged differently than in striated muscle.],
    path: "../fig/image_place_holder.png"
  ),
  "12-36": (
    caption: [Excitation-contraction coupling in smooth muscle. Ca²⁺ entering through voltage-gated channels binds to calmodulin, forming a complex that activates myosin light-chain kinase (MLCK). Activated MLCK phosphorylates myosin light chains, activating cross-bridges. Myosin phosphatase ends contraction by dephosphorylating myosin.],
    path: "../fig/image_place_holder.png"
  ),
  "12-37": (
    caption: [Single-unit and multiunit smooth muscle types. In single-unit smooth muscle, cells are electrically coupled by gap junctions allowing coordinated contractions. In multiunit smooth muscle, each cell must be individually stimulated by autonomic neurons forming synapses en passant with varicosities.],
    path: "../fig/image_place_holder.png"
  ),
  "table-12-1": (
    caption: [Skeletal muscle actions, defining key terms including origin, insertion, agonist, antagonist, synergist, flexor, extensor, abductor, and adductor muscles.],
    path: "../fig/image_place_holder.png"
  ),
  "table-12-2": (
    caption: [Summary of the sliding filament theory of contraction, describing changes in sarcomere components (A bands, H bands, I bands, and distance between Z lines) during muscle contraction.],
    path: "../fig/image_place_holder.png"
  ),
  "table-12-3": (
    caption: [Characteristics of muscle fiber types, comparing slow oxidative (type I), fast oxidative (type IIA), and fast glycolytic (type IIX) fibers in terms of diameter, Z-line thickness, glycogen content, resistance to fatigue, capillaries, myoglobin content, and color.],
    path: "../fig/image_place_holder.png"
  ),
  "table-12-4": (
    caption: [Effects of endurance training on skeletal muscles, listing changes in muscle structure and metabolism including increased mitochondria, capillaries, myoglobin, and oxidative enzymes.],
    path: "../fig/image_place_holder.png"
  ),
  "table-12-5": (
    caption: [Partial listing of terms used to describe neural control of skeletal muscles, defining lower motor neurons, upper motor neurons, alpha motor neurons, and gamma motor neurons.],
    path: "../fig/image_place_holder.png"
  ),
  "table-12-6": (
    caption: [Summary of events in a monosynaptic stretch reflex, describing the sequence from muscle stretch through spindle activation to muscle contraction via direct alpha motor neuron stimulation.],
    path: "../fig/image_place_holder.png"
  ),
  "table-12-7": (
    caption: [Symptoms of upper motor neuron damage, listing spastic paralysis, Babinski reflex, and hyperactive stretch reflexes as consequences of damage to descending motor pathways.],
    path: "../fig/image_place_holder.png"
  ),
  "table-12-8": (
    caption: [Comparison of skeletal, cardiac, and smooth muscle types, contrasting their structural features, regulation mechanisms, and functional properties including striation patterns, calcium sources, and control systems.],
    path: "../fig/image_place_holder.png"
  )
