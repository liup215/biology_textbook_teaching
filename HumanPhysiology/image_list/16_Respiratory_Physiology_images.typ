#let images = (
  "16-1": (
    caption: [The relationship between *lung alveoli* and *pulmonary capillaries*. The alveolar walls are narrow and lined with *type I* and *type II alveolar cells*. *Type I cells* facilitate gas exchange, while *type II cells* secrete *pulmonary surfactant*. *Pulmonary macrophages* phagocytose particles that enter the lungs, providing immune defense.],
    path: "../fig/image_place_holder.png"
  ),
  "16-2": (
    caption: [An *electron micrograph* of a capillary within the alveolar wall. The extremely short distance (approximately 0.3 μm) between the alveolar space and capillary enables efficient gas exchange. EP = *epithelial cell* of alveolus; EN = *endothelial cell* of capillary; RBC = *red blood cell*; BM = *basement membrane*; IS = *interstitial connective tissue*.],
    path: "../fig/image_place_holder.png"
  ),
  "16-3": (
    caption: [A *scanning electron micrograph* of lung tissue showing: (a) A small *bronchiole* passing between many alveoli, and (b) Alveoli under higher magnification with an arrow indicating an *alveolar pore* through which air can pass between adjacent alveoli, providing collateral ventilation.],
    path: "../fig/image_place_holder.png"
  ),
  "16-4": (
    caption: [The *conducting zone* and *respiratory zone* of the respiratory system. The conducting zone includes all airways that conduct air but do not participate in gas exchange (trachea, bronchi, bronchioles, terminal bronchioles). The respiratory zone is where gas exchange occurs (respiratory bronchioles and alveolar sacs). Numbers in parentheses show the quantity of each structure, demonstrating the extensive branching that increases surface area.],
    path: "../fig/image_place_holder.png"
  ),
  "16-5": (
    caption: [The conducting zone of the respiratory system: (a) An anterior view from the *larynx* to the terminal bronchi showing the branching pattern of the airway tree, and (b) A plastic cast representation from the *trachea* to the *terminal bronchioles*, illustrating the three-dimensional structure of the bronchial tree.],
    path: "../fig/image_place_holder.png"
  ),
  "16-6": (
    caption: [Photograph of the *larynx* showing the true and false vocal cords and the *glottis*. The *vocal folds* (true vocal cords) produce sound through vibration, whereas the *ventricular folds* (false vocal cords) do not participate in sound production but protect the airway.],
    path: "../fig/image_place_holder.png"
  ),
  "16-7": (
    caption: [Cross section of the *thoracic cavity* showing the lungs, *mediastinum*, and *pleural membranes*. The *parietal pleura* (shown in green) lines the thoracic wall, while the *visceral pleura* (shown in blue) covers the lung surface. The *intrapleural space* between these membranes contains a thin layer of fluid that allows smooth movement during breathing.],
    path: "../fig/image_place_holder.png"
  ),
  "16-8": (
    caption: [*Radiographic* (x-ray) views of the chest showing: (a) a normal female chest and (b) a normal male chest. These images demonstrate the normal position and size of the lungs within the thoracic cavity, with the heart visible in the central mediastinum.],
    path: "../fig/image_place_holder.png"
  ),
  "table-16-1": (
    caption: [*Pressure changes* in normal, quiet breathing. This table shows the changes in *intrapulmonary pressure* and *intrapleural pressure* during different phases of the respiratory cycle, demonstrating the pressure gradients that drive airflow.],
    path: "../fig/image_place_holder.png"
  ),
  "16-9": (
    caption: [A *pneumothorax* of the right lung. The right side of the thorax appears uniformly dark due to air accumulation in the pleural space. The spaces between ribs are wider on the right side because the lung has collapsed, releasing elastic tension. This condition disrupts the normal pressure gradients required for breathing.],
    path: "../fig/image_place_holder.png"
  ),
  "16-10": (
    caption: [The *law of Laplace* applied to alveoli. According to this law, surface tension creates greater pressure in smaller alveoli than in larger ones, which would cause smaller alveoli to collapse into larger ones. *Pulmonary surfactant* prevents this by reducing surface tension more in smaller alveoli, stabilizing all alveoli regardless of size.],
    path: "../fig/image_place_holder.png"
  ),
  "16-11": (
    caption: [The production of *pulmonary surfactant* by *type II alveolar cells*. Surfactant is composed of phospholipids (primarily *dipalmitoylphosphatidylcholine*, a derivative of lecithin) combined with proteins. It reduces surface tension in alveoli, preventing collapse and reducing the work of breathing.],
    path: "../fig/image_place_holder.png"
  ),
  "16-12": (
    caption: [Changes in lung volume during breathing shown by radiographs: (a) during *expiration* and (b) during *inspiration*. The comparison demonstrates the significant increase in lung volume during full inspiration due to contraction of the diaphragm and external intercostal muscles, and the decrease during expiration.],
    path: "../fig/image_place_holder.png"
  ),
  "16-13": (
    caption: [The muscles involved in breathing. *Principal muscles of inspiration* (left): *diaphragm* and *external intercostal muscles* for normal breathing, plus *sternocleidomastoid* and *scalene muscles* for forced inspiration. *Muscles of expiration* (right): normally passive, but *internal intercostal muscles* and *abdominal muscles* contract during forced expiration.],
    path: "../fig/image_place_holder.png"
  ),
  "table-16-2": (
    caption: [Mechanisms involved in normal, quiet *ventilation* and *forced ventilation*. This table compares the muscles used and pressure changes during: (1) normal quiet inspiration and expiration, and (2) forced inspiration and expiration, showing how breathing effort can be increased when needed.],
    path: "../fig/image_place_holder.png"
  ),
  "16-14": (
    caption: [The mechanics of *pulmonary ventilation* showing pressures at sea level: (a) before inspiration (equilibrium), (b) during inspiration (negative intrapulmonary pressure), and (c) during expiration (positive intrapulmonary pressure). The pressure gradients between atmosphere and alveoli drive airflow according to *Boyle's law*.],
    path: "../fig/image_place_holder.png"
  ),
  "16-15": (
    caption: [A *spirogram* showing lung volumes and capacities. *Lung volumes* include: *tidal volume* (normal breath), *inspiratory reserve volume* (additional air inhaled), *expiratory reserve volume* (additional air exhaled), and *residual volume* (air remaining after maximal exhalation). *Lung capacities* are sums of volumes: *vital capacity*, *inspiratory capacity*, *functional residual capacity*, and *total lung capacity*.],
    path: "../fig/image_place_holder.png"
  ),
  "table-16-3": (
    caption: [Terms used to describe *lung volumes* and *capacities*. This comprehensive table defines each measurement, including *tidal volume* (TV), *inspiratory reserve volume* (IRV), *expiratory reserve volume* (ERV), *residual volume* (RV), *vital capacity* (VC), *inspiratory capacity* (IC), *functional residual capacity* (FRC), and *total lung capacity* (TLC).],
    path: "../fig/image_place_holder.png"
  ),
  "16-16": (
    caption: [The one-second *forced expiratory volume* (*FEV₁*) test. Graph (a) shows a normal FEV₁/FVC ratio (typically >80%), while graph (b) shows a reduced ratio that may indicate *obstructive pulmonary disorders* such as asthma, chronic bronchitis, or emphysema, where airway resistance is increased.],
    path: "../fig/image_place_holder.png"
  ),
  "table-16-4": (
    caption: [*Ventilation terminology* defining key respiratory measurements. Includes *minute ventilation* (total air moved per minute), *alveolar ventilation* (air reaching alveoli per minute), and *anatomical dead space* (volume of conducting airways where no gas exchange occurs).],
    path: "../fig/image_place_holder.png"
  ),
  "16-17": (
    caption: [*Emphysema* destroys lung tissue. Photomicrographs compare: (a) tissue from a normal lung with numerous small alveoli, and (b) tissue from an emphysema patient showing destruction of alveolar walls, resulting in fewer but larger air spaces. This reduces surface area for gas exchange and causes loss of elastic recoil.],
    path: "../fig/image_place_holder.png"
  ),
  "16-18": (
    caption: [The measurement of *atmospheric pressure* using a mercury barometer. At sea level, atmospheric pressure can push a column of mercury to 760 millimeters height, which equals 760 torr or one atmosphere (1 atm). This standard pressure is the reference for all respiratory pressure measurements.],
    path: "../fig/image_place_holder.png"
  ),
  "table-16-5": (
    caption: [Effect of *altitude* on *partial oxygen pressure* (P_O₂). As altitude increases, atmospheric pressure decreases, reducing the partial pressure of oxygen available for respiration. This table shows P_O₂ values at different altitudes, explaining why breathing becomes more difficult at high elevations.],
    path: "../fig/image_place_holder.png"
  ),
  "16-19": (
    caption: [*Partial pressures* of gases in inspired air and alveolar air at sea level. As air enters the alveoli, oxygen content decreases (from 159 mmHg to 105 mmHg) due to oxygen absorption into blood, while carbon dioxide content increases (from 0.3 mmHg to 40 mmHg) due to CO₂ diffusion from blood. Alveolar air is also saturated with water vapor.],
    path: "../fig/image_place_holder.png"
  ),
  "16-20": (
    caption: [The relationship between alveoli and blood vessels. The extensive contact area between *pulmonary capillaries* and alveoli enables rapid and efficient gas exchange. Each alveolus is surrounded by a dense network of capillaries, maximizing the surface area for diffusion.],
    path: "../fig/image_place_holder.png"
  ),
  "16-21": (
    caption: [Blood gas measurements using the *P_O₂ electrode*. The electrode is first calibrated using solutions of known oxygen concentration, then can be inserted into blood samples to measure P_O₂. This technique is essential for assessing respiratory function and blood oxygenation in clinical settings.],
    path: "../fig/image_place_holder.png"
  ),
  "16-22": (
    caption: [*Partial pressures* of gases in blood. This diagram shows P_O₂ and P_CO₂ values in: (1) deoxygenated blood entering pulmonary capillaries (P_O₂ = 40 mmHg, P_CO₂ = 46 mmHg), (2) oxygenated blood leaving lungs (P_O₂ = 105 mmHg, P_CO₂ = 40 mmHg), and (3) systemic capillaries where gas exchange with tissues occurs.],
    path: "../fig/image_place_holder.png"
  ),
  "16-23": (
    caption: [Lung *ventilation/perfusion* (V/Q) *ratios*. The apex of the lungs has a higher V/Q ratio (relatively overventilated compared to blood flow), while the base has a lower V/Q ratio (relatively underventilated). This regional variation affects gas exchange efficiency and explains why certain lung diseases preferentially affect specific regions.],
    path: "../fig/image_place_holder.png"
  ),
  "16-24": (
    caption: [Approximate locations of the *brain stem respiratory centers*. The *rhythmicity center* in the *medulla oblongata* (containing dorsal and ventral respiratory groups) directly controls breathing rhythm. It receives modulating input from the *pneumotaxic center* and *apneustic center* in the pons, and from chemoreceptors.],
    path: "../fig/image_place_holder.png"
  ),
  "16-25": (
    caption: [Sensory input from the *aortic bodies* and *carotid bodies*. These *peripheral chemoreceptors* detect changes in arterial P_O₂, P_CO₂, and pH, then send signals via the *glossopharyngeal nerve* (IX) and *vagus nerve* (X) to the brain stem respiratory centers, providing rapid feedback control of ventilation.],
    path: "../fig/image_place_holder.png"
  ),
  "16-26": (
    caption: [The regulation of ventilation by the *central nervous system*. This flowchart shows how the *medullary rhythmicity center* controls inspiration and expiration through motor output to respiratory muscles. The system receives input from *central chemoreceptors*, *peripheral chemoreceptors*, and *higher brain centers*, creating a sophisticated feedback control system.],
    path: "../fig/image_place_holder.png"
  ),
  "16-27": (
    caption: [The relationship between *total minute volume* and arterial P_CO₂. These are inversely related: when minute ventilation increases by a factor of 2, arterial P_CO₂ decreases by half. This demonstrates the importance of ventilation in regulating blood CO₂ levels and, consequently, blood pH.],
    path: "../fig/image_place_holder.png"
  ),
  "16-28": (
    caption: [*Chemoreceptor* control of breathing showing *negative feedback* regulation. Increased blood CO₂ crosses the *blood-brain barrier*, forms carbonic acid in cerebrospinal fluid, and releases H⁺ ions that stimulate *central chemoreceptors* in the medulla. This increases ventilation, which lowers blood CO₂, completing the feedback loop.],
    path: "../fig/image_place_holder.png"
  ),
  "16-29": (
    caption: [How blood CO₂ affects chemoreceptors in the *medulla oblongata*. An increase in blood CO₂ stimulates breathing indirectly by lowering the pH of blood and *cerebrospinal fluid* (CSF). CO₂ diffuses across the blood-brain barrier, forms H⁺ ions, which then stimulate central chemoreceptors.],
    path: "../fig/image_place_holder.png"
  ),
  "table-16-6": (
    caption: [Sensitivity of *chemoreceptors* to changes in blood gases and pH. *Central chemoreceptors* primarily respond to changes in blood CO₂ (indirectly via pH changes in CSF), while *peripheral chemoreceptors* (carotid and aortic bodies) respond to P_O₂, P_CO₂, and pH. This table shows the relative sensitivity of each receptor type.],
    path: "../fig/image_place_holder.png"
  ),
  "16-30": (
    caption: [Comparing the effects of blood CO₂ and O₂ on breathing. Increases in blood CO₂ concentration produce large increases in minute ventilation (steep curve), while decreases in blood P_O₂ only stimulate breathing significantly when P_O₂ falls below 60 mmHg (shallow curve until hypoxic threshold). CO₂ is thus the primary regulator of ventilation under normal conditions.],
    path: "../fig/image_place_holder.png"
  ),
  "16-31": (
    caption: [The oxygen content of blood. Plasma and whole blood equilibrated with the same P_O₂ contain vastly different amounts of oxygen. Most oxygen (>98%) is carried bound to *hemoglobin* in red blood cells, while only a small fraction (~2%) is dissolved in plasma. This demonstrates hemoglobin's crucial role in oxygen transport.],
    path: "../fig/image_place_holder.png"
  ),
  "16-32": (
    caption: [The structure of *hemoglobin*. (a) Three-dimensional structure showing two *alpha chains* and two *beta chains* (quaternary structure), each containing a *heme group* with an iron atom that binds oxygen. (b) Detailed view of a heme group with its porphyrin ring and central Fe²⁺ ion. Each hemoglobin molecule can bind four oxygen molecules cooperatively.],
    path: "../fig/image_place_holder.png"
  ),
  "table-16-7": (
    caption: [Relationship between percent *oxyhemoglobin saturation* and P_O₂ at pH 7.40 and 37°C. This table provides numerical values for the *oxyhemoglobin dissociation curve*, showing how hemoglobin saturation changes with P_O₂. At normal arterial P_O₂ (100 mmHg), hemoglobin is ~97% saturated; at normal venous P_O₂ (40 mmHg), it is ~75% saturated.],
    path: "../fig/image_place_holder.png"
  ),
  "16-33": (
    caption: [The *oxyhemoglobin dissociation curve* showing the S-shaped (sigmoid) relationship between P_O₂ and hemoglobin saturation. The curve's shape reflects *cooperative binding*: initial oxygen binding facilitates subsequent binding. The steep middle portion ensures efficient oxygen loading in lungs and unloading in tissues.],
    path: "../fig/image_place_holder.png"
  ),
  "table-16-8": (
    caption: [Effect of pH on hemoglobin affinity for oxygen and oxygen unloading to tissues. Lower pH (higher H⁺ concentration) decreases hemoglobin's oxygen affinity, shifting the dissociation curve rightward. This *Bohr effect* facilitates oxygen unloading in metabolically active tissues that produce CO₂ and H⁺.],
    path: "../fig/image_place_holder.png"
  ),
  "16-34": (
    caption: [The effect of pH on the *oxyhemoglobin dissociation curve* (the *Bohr effect*). Decreased blood pH (increased H⁺ concentration) shifts the curve to the right, decreasing hemoglobin's oxygen affinity. This adaptation helps deliver more oxygen to tissues producing acids (like actively metabolizing muscle), where pH is lower.],
    path: "../fig/image_place_holder.png"
  ),
  "16-35": (
    caption: [*2,3-DPG* (2,3-diphosphoglycerate) promotes oxygen unloading to tissues. Production of 2,3-DPG is inhibited by oxyhemoglobin, so when blood P_O₂ is reduced (e.g., at high altitude), less oxyhemoglobin leads to more 2,3-DPG production. 2,3-DPG binds to deoxyhemoglobin, stabilizing it and shifting the dissociation curve rightward.],
    path: "../fig/image_place_holder.png"
  ),
  "table-16-9": (
    caption: [Factors that affect hemoglobin's affinity for oxygen and the position of the *oxyhemoglobin dissociation curve*. *Rightward shifts* (decreased affinity, enhanced unloading): increased temperature, increased P_CO₂, decreased pH, increased 2,3-DPG. *Leftward shifts* (increased affinity, reduced unloading): opposite conditions.],
    path: "../fig/image_place_holder.png"
  ),
  "16-36": (
    caption: [*Sickle-cell anemia* showing: (a) normal red blood cells with their characteristic biconcave disc shape, and (b) sickled red blood cells with abnormal crescent shape seen in scanning electron microscope. Sickling occurs due to a mutation in the beta chain of hemoglobin, causing cells to deform under low oxygen conditions.],
    path: "../fig/image_place_holder.png"
  ),
  "16-37": (
    caption: [Comparison of dissociation curves for *hemoglobin* and *myoglobin*. Myoglobin, an oxygen-binding protein in skeletal muscles, has a hyperbolic (not sigmoid) curve and much higher oxygen affinity than hemoglobin. At the low P_O₂ in exercising muscle, hemoglobin releases oxygen while myoglobin retains it, allowing myoglobin to serve as an oxygen reserve.],
    path: "../fig/image_place_holder.png"
  ),
  "16-38": (
    caption: [*Carbon dioxide transport* and the *chloride shift*. CO₂ is transported in three forms: (1) dissolved CO₂ gas (~7%), (2) bound to hemoglobin as *carbaminohemoglobin* (~23%), and (3) as bicarbonate ions (HCO₃⁻) (~70%). The chloride shift is the exchange of bicarbonate for chloride ions across the red blood cell membrane, maintaining electrical neutrality.],
    path: "../fig/image_place_holder.png"
  ),
  "16-39": (
    caption: [The *reverse chloride shift* in the lungs. As blood travels through pulmonary capillaries, CO₂ is released from blood into alveoli. Bicarbonate re-enters red blood cells (in exchange for chloride), combines with H⁺ to form carbonic acid, which dissociates into CO₂ and H₂O. The CO₂ then diffuses into alveoli for exhalation.],
    path: "../fig/image_place_holder.png"
  ),
  "16-40": (
    caption: [The effect of bicarbonate on blood pH. Bicarbonate (HCO₃⁻) released from red blood cells into plasma acts as a *buffer*, combining with H⁺ ions produced by metabolic processes. This buffering system helps maintain blood pH within the narrow physiological range (7.35-7.45) required for proper enzyme function.],
    path: "../fig/image_place_holder.png"
  ),
  "table-16-10": (
    caption: [Terms used to describe *acid-base balance*. Definitions include: *acidosis* (blood pH <7.35), *alkalosis* (blood pH >7.45), *metabolic acidosis/alkalosis* (caused by changes in bicarbonate concentration), and *respiratory acidosis/alkalosis* (caused by changes in P_CO₂ from altered ventilation).],
    path: "../fig/image_place_holder.png"
  ),
  "table-16-11": (
    caption: [Classification of *metabolic* and *respiratory* components of *acidosis* and *alkalosis*. Shows how to distinguish the primary disorder (respiratory vs. metabolic) and identify compensation by examining pH, P_CO₂, and HCO₃⁻ levels in blood gas analysis.],
    path: "../fig/image_place_holder.png"
  ),
  "table-16-12": (
    caption: [Effect of lung function on blood *acid-base balance*. *Hypoventilation* increases blood CO₂, decreases pH, causing *respiratory acidosis*. *Hyperventilation* decreases blood CO₂, increases pH, causing *respiratory alkalosis*. This demonstrates the lungs' crucial role in pH regulation.],
    path: "../fig/image_place_holder.png"
  ),
  "16-41": (
    caption: [The effect of *exercise* on arterial blood gases and pH. During moderate and heavy exercise, arterial P_O₂, P_CO₂, and pH remain relatively constant for the first several minutes. Only P_CO₂ may show slight changes during very heavy exercise, demonstrating the body's remarkable ability to maintain homeostasis during increased metabolic demand.],
    path: "../fig/image_place_holder.png"
  ),
  "table-16-13": (
    caption: [Changes in respiratory function during *exercise*. Shows increases in *tidal volume*, *breathing rate*, *minute ventilation*, and *pulmonary blood flow*, while arterial blood gases remain stable. This demonstrates how ventilation increases proportionally to metabolic rate to maintain gas homeostasis.],
    path: "../fig/image_place_holder.png"
  ),
  "table-16-14": (
    caption: [Blood gas measurements at different altitudes. As altitude increases, atmospheric pressure and P_O₂ decrease, leading to lower arterial P_O₂ and oxyhemoglobin saturation. This *hypoxia* triggers physiological adaptations for *acclimatization* to high altitude.],
    path: "../fig/image_place_holder.png"
  ),
  "table-16-15": (
    caption: [Changes in respiratory function during *acclimatization* to high altitude. Adaptations include: increased ventilation (immediate), increased 2,3-DPG production (hours-days), increased red blood cell production via *erythropoietin* (weeks), and increased capillary density (months). These changes improve oxygen delivery despite reduced atmospheric P_O₂.],
    path: "../fig/image_place_holder.png"
  ),
  "16-42": (
    caption: [Respiratory adaptations to high altitude. The circled numbers indicate the temporal sequence of responses: (1) immediate hyperventilation, (2) increased 2,3-DPG within hours, (3) increased erythropoietin secretion by kidneys within days, (4) increased red blood cell production over weeks, (5) increased capillary density over months. These adaptations enable people to live, work, and perform at higher altitudes.],
    path: "../fig/image_place_holder.png"
  )
)
