#let images = (
  "11-1": (
    caption: [The major endocrine glands showing (a) the anatomical location of the major endocrine glands in the human body, and (b) a photomicrograph of a pancreatic islet (islet of Langerhans) within the pancreas, demonstrating the structural organization of endocrine tissue.],
    path: "../fig/image_place_holder.png"
  ),
  "table-11-1": (
    caption: [A partial listing of the endocrine glands, their locations, and the hormones they secrete. This table provides an overview of the major endocrine organs and their primary hormonal secretions.],
    path: "../fig/image_place_holder.png"
  ),
  "11-2": (
    caption: [Simplified biosynthetic pathways for steroid hormones. This diagram illustrates that progesterone (secreted by the corpus luteum of the ovaries) serves as a common precursor for all other steroid hormones, and shows how testosterone and other androgens can be converted to estrogens through enzymatic pathways in the adrenal cortex and gonads.],
    path: "../fig/image_place_holder.png"
  ),
  "table-11-2": (
    caption: [Examples of polypeptide and glycoprotein hormones, showing their chemical composition and representative examples from various endocrine glands including the pituitary, pancreas, and parathyroid glands.],
    path: "../fig/image_place_holder.png"
  ),
  "11-3": (
    caption: [Structural formulas for the thyroid hormones. This shows the molecular structures of thyroxine (tetraiodothyronine, T₄) and triiodothyronine (T₃), which are secreted by the thyroid gland in a ratio of 9:1 and are both derived from the amino acid tyrosine.],
    path: "../fig/image_place_holder.png"
  ),
  "table-11-3": (
    caption: [Conversion of prehormones into biologically active derivatives. This table demonstrates how inactive precursor molecules are enzymatically modified in various tissues to produce active hormones, illustrating the importance of post-secretory processing in hormone regulation.],
    path: "../fig/image_place_holder.png"
  ),
  "11-4": (
    caption: [The mechanism of steroid hormone action. (1) Steroid hormones dissociate from plasma carrier proteins and pass through the plasma membrane of target cells. (2) In the cytoplasm or nucleus, they bind to nuclear receptor proteins. (3) The hormone-receptor complex binds to hormone-response elements on DNA. (4) This leads to gene transcription and mRNA production, ultimately resulting in new protein synthesis.],
    path: "../fig/image_place_holder.png"
  ),
  "11-5": (
    caption: [Receptors for steroid hormones showing (a) the structure of nuclear hormone receptor proteins with ligand-binding and DNA-binding domains, and (b) how these receptors bind to hormone-response elements in DNA as dimers, with each receptor recognizing specific half-sites separated by nucleotide spacers.],
    path: "../fig/image_place_holder.png"
  ),
  "11-6": (
    caption: [The mechanism of thyroid hormone action. (1) Thyroxine (T₄) dissociates from its plasma carrier protein and enters the target cell. (2) T₄ is converted to T₃ (the more active form) inside the cell. (3) T₃ enters the nucleus and binds to nuclear receptor proteins. (4) The T₃-receptor complex regulates gene transcription, leading to changes in cellular metabolism.],
    path: "../fig/image_place_holder.png"
  ),
  "11-7": (
    caption: [The receptor for triiodothyronine (T₃). The nuclear receptor protein for T₃ forms a heterodimer with the receptor protein for 9-cis-retinoic acid (a derivative of vitamin A). This heterodimerization occurs when each receptor binds to its respective half-site on the DNA hormone-response element.],
    path: "../fig/image_place_holder.png"
  ),
  "table-11-4": (
    caption: [Sequence of events involving cyclic AMP as a second messenger. This table outlines the step-by-step process from hormone binding to cellular response in the cAMP signaling pathway.],
    path: "../fig/image_place_holder.png"
  ),
  "11-8": (
    caption: [The adenylate cyclase–cyclic AMP second-messenger system. (1) Hormone binds to its receptor in the plasma membrane. (2) This causes dissociation and activation of G-proteins. (3) The activated G-protein subunit stimulates adenylate cyclase. (4) Adenylate cyclase converts ATP to cyclic AMP (cAMP). (5) cAMP activates protein kinase A. (6) Protein kinase A phosphorylates target proteins, producing the cellular response.],
    path: "../fig/image_place_holder.png"
  ),
  "11-9": (
    caption: [The phospholipase C–Ca²⁺ second-messenger system. (1) Hormone binds to its receptor in the plasma membrane. (2) This causes G-protein dissociation. (3) An activated G-protein subunit stimulates phospholipase C. (4) Phospholipase C cleaves PIP₂ into IP₃ and DAG. (5) IP₃ stimulates Ca²⁺ release from endoplasmic reticulum. (6) Ca²⁺ and DAG activate protein kinase C and other enzymes, producing cellular responses.],
    path: "../fig/image_place_holder.png"
  ),
  "11-10": (
    caption: [Epinephrine uses two second-messenger systems. This diagram shows how epinephrine binding to beta-adrenergic receptors activates the cAMP pathway, while binding to alpha-adrenergic receptors activates the Ca²⁺ pathway in a liver cell. Both pathways ultimately lead to glycogen breakdown, demonstrating how a single hormone can utilize multiple signaling mechanisms.],
    path: "../fig/image_place_holder.png"
  ),
  "table-11-5": (
    caption: [Sequence of events involving the Ca²⁺ second-messenger system. This table details the cascade of events from hormone-receptor binding through calcium release and cellular response.],
    path: "../fig/image_place_holder.png"
  ),
  "11-11": (
    caption: [The receptor for insulin. The insulin receptor consists of two parts, each containing a beta polypeptide chain spanning the membrane and an alpha chain containing the insulin-binding site. (a) When insulin is not bound, the receptor is inactive. (b) Insulin binding causes autophosphorylation and activation of the receptor's tyrosine kinase activity, initiating intracellular signaling cascades.],
    path: "../fig/image_place_holder.png"
  ),
  "11-12": (
    caption: [The structure of the pituitary gland. The anterior lobe (adenohypophysis) is composed of glandular tissue, whereas the posterior lobe (neurohypophysis) is composed largely of neuroglia and nerve fibers. The pituitary stalk connects the gland to the hypothalamus.],
    path: "../fig/image_place_holder.png"
  ),
  "table-11-6": (
    caption: [Anterior pituitary hormones, listing the major hormones secreted by the anterior pituitary gland, their chemical nature, and their primary target organs and functions.],
    path: "../fig/image_place_holder.png"
  ),
  "11-13": (
    caption: [Hypothalamic control of the posterior pituitary. The posterior pituitary (neurohypophysis) stores and releases vasopressin (ADH) and oxytocin, which are actually produced by neurosecretory neurons in the supraoptic and paraventricular nuclei of the hypothalamus. These hormones travel down axons and are stored in nerve terminals in the posterior pituitary until released.],
    path: "../fig/image_place_holder.png"
  ),
  "11-14": (
    caption: [Hormones secreted by the anterior pituitary and their target organs. This diagram shows how the anterior pituitary controls several (but not all) other endocrine glands through tropic hormones including TSH, ACTH, FSH, LH, and also secretes hormones with direct effects such as growth hormone and prolactin.],
    path: "../fig/image_place_holder.png"
  ),
  "11-15": (
    caption: [Hypothalamic control of the anterior pituitary. Neurons in the hypothalamus secrete releasing hormones and inhibiting hormones into the hypothalamo-hypophyseal portal system (specialized blood vessels). These hormones travel through the portal veins to the anterior pituitary, where they regulate the secretion of anterior pituitary hormones.],
    path: "../fig/image_place_holder.png"
  ),
  "table-11-7": (
    caption: [Hypothalamic hormones involved in the control of the anterior pituitary, listing the releasing and inhibiting hormones produced by the hypothalamus and their effects on anterior pituitary hormone secretion.],
    path: "../fig/image_place_holder.png"
  ),
  "11-16": (
    caption: [The hypothalamus-pituitary-thyroid axis (control system). Thyroxine secretion from the thyroid is stimulated by thyroid-stimulating hormone (TSH) from the anterior pituitary. TSH secretion is stimulated by thyrotropin-releasing hormone (TRH) from the hypothalamus. This system demonstrates negative feedback control, where elevated thyroid hormones inhibit both TRH and TSH secretion.],
    path: "../fig/image_place_holder.png"
  ),
  "11-17": (
    caption: [The hypothalamus-pituitary-gonad axis (control system). The hypothalamus secretes GnRH (gonadotropin-releasing hormone), which stimulates the anterior pituitary to secrete FSH and LH (gonadotropins). These hormones stimulate the gonads to produce sex steroids (testosterone, estrogen, progesterone), which exert negative feedback on the hypothalamus and pituitary.],
    path: "../fig/image_place_holder.png"
  ),
  "11-18": (
    caption: [The structure of the adrenal gland, showing the adrenal cortex with its three distinct zones: zona glomerulosa (secretes mineralocorticoids like aldosterone), zona fasciculata (secretes glucocorticoids like cortisol), and zona reticularis (secretes sex steroids). The inner adrenal medulla secretes catecholamines (epinephrine and norepinephrine).],
    path: "../fig/image_place_holder.png"
  ),
  "11-19": (
    caption: [Simplified pathways for the synthesis of steroid hormones in the adrenal cortex. The adrenal cortex produces mineralocorticoids that regulate Na⁺ and K⁺ balance, glucocorticoids that regulate glucose metabolism and stress responses, and sex steroids. All are derived from cholesterol through specific enzymatic pathways.],
    path: "../fig/image_place_holder.png"
  ),
  "11-20": (
    caption: [Activation of the pituitary-adrenal axis by nonspecific stress. Stress stimulates the hypothalamus to secrete CRH (corticotropin-releasing hormone), which stimulates the anterior pituitary to secrete ACTH (adrenocorticotropic hormone). ACTH stimulates the adrenal cortex to secrete cortisol. Negative feedback control (shown by blue arrows) occurs as cortisol inhibits both CRH and ACTH secretion.],
    path: "../fig/image_place_holder.png"
  ),
  "11-21": (
    caption: [The thyroid gland and its anatomical relationship to the larynx and trachea. The thyroid consists of two lobes connected by an isthmus, positioned anterior to the trachea in the neck.],
    path: "../fig/image_place_holder.png"
  ),
  "11-22": (
    caption: [A photomicrograph (250×) of thyroid gland tissue showing numerous thyroid follicles. Each follicle consists of a single layer of follicular cells surrounding a central cavity filled with colloid, which contains the protein thyroglobulin where thyroid hormones are synthesized and stored.],
    path: "../fig/image_place_holder.png"
  ),
  "11-23": (
    caption: [The production and storage of thyroid hormones. Iodide is actively transported from blood into follicular cells via the Na⁺/I⁻ symporter. In the colloid, iodide is oxidized to iodine and attached to tyrosine residues within thyroglobulin molecules. Coupling reactions form T₃ and T₄. When stimulated by TSH, thyroglobulin is taken back into follicular cells, hydrolyzed, and T₃ and T₄ are released into the bloodstream.],
    path: "../fig/image_place_holder.png"
  ),
  "11-24": (
    caption: [Endemic goiter caused by insufficient dietary iodine. A lack of iodine leads to hypothyroidism, and the resulting elevation in TSH secretion (due to reduced negative feedback) stimulates excessive growth and enlargement of the thyroid gland, forming a visible goiter.],
    path: "../fig/image_place_holder.png"
  ),
  "11-25": (
    caption: [How iodine deficiency causes a goiter. This flowchart shows the mechanism: inadequate dietary iodine → low thyroid hormone production → reduced negative feedback → elevated TSH secretion → thyroid gland hypertrophy → goiter formation.],
    path: "../fig/image_place_holder.png"
  ),
  "11-26": (
    caption: [A symptom of hyperthyroidism showing exophthalmos (protruding eyes). Hyperthyroidism is characterized by increased metabolic rate, weight loss, muscular weakness, nervousness, and in Graves' disease, eye protrusion due to edema in the orbital tissues behind the eyes.],
    path: "../fig/image_place_holder.png"
  ),
  "table-11-8": (
    caption: [Comparison of hypothyroidism and hyperthyroidism, contrasting the causes, symptoms, and physiological effects of insufficient versus excessive thyroid hormone production.],
    path: "../fig/image_place_holder.png"
  ),
  "11-27": (
    caption: [A posterior view of the parathyroid glands. Typically four small parathyroid glands are embedded in the posterior surface of the thyroid gland. These glands secrete parathyroid hormone (PTH), which regulates blood calcium levels.],
    path: "../fig/image_place_holder.png"
  ),
  "11-28": (
    caption: [The actions of parathyroid hormone (PTH) and the control of its secretion. Low blood calcium stimulates PTH secretion. PTH acts on bones (increasing calcium release), kidneys (increasing calcium reabsorption and decreasing phosphate reabsorption), and indirectly on intestines (by activating vitamin D₃) to raise blood calcium levels. Elevated calcium exerts negative feedback to inhibit PTH secretion.],
    path: "../fig/image_place_holder.png"
  ),
  "11-29": (
    caption: [The pancreas and associated pancreatic islets (islets of Langerhans). Alpha cells secrete glucagon and beta cells secrete insulin. The pancreas has both endocrine functions (hormone secretion from islets) and exocrine functions (digestive enzyme secretion into pancreatic ducts).],
    path: "../fig/image_place_holder.png"
  ),
  "11-30": (
    caption: [Insulin stimulates uptake of blood glucose. (1) Insulin binding to its plasma membrane receptors activates cytoplasmic signaling molecules. (2) These signals cause intracellular vesicles containing GLUT4 glucose transporters to move to and fuse with the plasma membrane. (3) This increases the number of glucose transporters on the cell surface, enhancing glucose uptake from the blood into cells, particularly in muscle and adipose tissue.],
    path: "../fig/image_place_holder.png"
  ),
  "11-31": (
    caption: [Glucose homeostasis is maintained by insulin and glucagon. (a) When plasma glucose rises after a meal, beta cells secrete more insulin (and alpha cells are inhibited), promoting glucose uptake and storage. (b) When plasma glucose falls during fasting, alpha cells secrete more glucagon (and beta cells are inhibited), promoting glucose release from storage. This demonstrates antagonistic regulation of blood glucose.],
    path: "../fig/image_place_holder.png"
  ),
  "11-32": (
    caption: [A simplified biosynthetic pathway for melatonin. Melatonin is synthesized from the amino acid tryptophan through serotonin. The enzyme that converts serotonin to melatonin is activated at night, resulting in circadian (daily) rhythms of melatonin secretion tied to light-dark cycles.],
    path: "../fig/image_place_holder.png"
  ),
  "11-33": (
    caption: [The secretion of melatonin by the pineal gland. Melatonin secretion is stimulated by sympathetic neurons originating from the superior cervical ganglion. The activity of these neurons is regulated by the suprachiasmatic nucleus (SCN) of the hypothalamus, which receives input from the retina, making melatonin secretion responsive to light-dark cycles and serving as a timing signal for circadian rhythms.],
    path: "../fig/image_place_holder.png"
  ),
  "table-11-9": (
    caption: [Examples of autocrine and paracrine regulators, listing local signaling molecules that act on the cells that secrete them (autocrine) or on nearby cells (paracrine) rather than traveling through the bloodstream. Examples include growth factors, cytokines, and prostaglandins.],
    path: "../fig/image_place_holder.png"
  ),
  "11-34": (
    caption: [The formation of leukotrienes and prostaglandins from arachidonic acid. Phospholipase A₂ releases arachidonic acid from membrane phospholipids. The lipoxygenase pathway produces leukotrienes (involved in inflammation and immune responses), while the cyclooxygenase (COX) pathway produces prostaglandins and thromboxanes (involved in inflammation, pain, fever, blood clotting, and smooth muscle contraction). This diagram summarizes the major actions of these autocrine/paracrine regulators.],
    path: "../fig/image_place_holder.png"
  )
)
