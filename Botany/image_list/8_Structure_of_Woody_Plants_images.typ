#let images = (
  "8-1": (
    caption: [Young stem of elderberry (Sambucus) showing the beginning of secondary growth. A vascular cambium has formed and produced a small amount of secondary xylem (wood) and secondary phloem. The primary tissues are still present (315).],
    path: "../fig/fig-2025-12-12-11-35-15.png"
  ),
  "8-2": (
    caption: [Secondary growth. (A) A fascicular cambium is derived from the procambium within a vascular bundle. (B) An interfascicular cambium is derived from parenchyma cells of the interfascicular regions. (C) The two cambia become united into a continuous cylinder, the vascular cambium.],
    path: "../fig/fig-2025-12-12-11-35-43.png"
  ),
  "8-3": (
    caption: [Diagram of secondary growth. (A) A young stem with primary growth; vascular bundles are arranged in a circle. (B) The vascular cambium has formed and has produced a continuous layer of secondary xylem (wood) and secondary phloem. The primary xylem and phloem have been pushed apart. (C) The stem after another year of growth. The vascular cambium has moved outward, pushing the secondary phloem outward. The primary phloem is being stretched and destroyed. (D) A three-year-old stem. The wood is now quite thick, and the pith is small. The primary phloem is gone, and the epidermis and cortex are being shed.],
    path: "../fig/fig-2025-12-12-11-36-07.png"
  ),
  "8-4": (
    caption: [Fusiform initials are long, flat cells. (A) In tangential section, they appear wide. (B) In radial section, they appear narrow.],
    path: "../fig/fig-2025-12-12-11-36-34.png"
  ),
  "8-5": (
    caption: [Ray initials are short, cuboidal cells. (A) In tangential section, they appear as a vertical row of cells. (B) In radial section, they appear as a horizontal row of cells.],
    path: "../fig/fig-2025-12-12-11-37-08.png"
  ),
  "8-6": (
    caption: [Division of a fusiform initial. (A) A fusiform initial. (B) The cell has divided by a periclinal wall, forming two cells. The inner cell will differentiate into a xylem cell, and the outer cell remains a fusiform initial. (C) The xylem cell differentiates, and the fusiform initial expands to its original size. (D) The fusiform initial divides again by a periclinal wall. (E) The outer cell differentiates into a phloem cell, and the inner cell remains a fusiform initial. (F) The fusiform initial divides by an anticlinal wall, forming two fusiform initials side by side.],
    path: "../fig/fig-2025-12-12-11-37-34.png"
  ),
  "8-7": (
    caption: [Tangential section of the wood of persimmon (Diospyros virginiana). The fusiform initials were nonstoried; that is, they were not aligned horizontally. Consequently, the ends of the wood fibers overlap in a random pattern. The rays are two to three cells wide (3100).],
    path: "../fig/fig-2025-12-12-11-37-55.png"
  ),
  "8-8": (
    caption: [Radial section of the wood of persimmon. The rays appear as sheets of cells. The fibers are vertical. The vessels are not visible in this section (3100).],
    path: "../fig/fig-2025-12-12-11-38-11.png"
  ),
  "8-9": (
    caption: [Transverse section of the wood of persimmon. The rays appear as lines of cells. The vessels are large and round. The fibers are small and thick-walled (3100).],
    path: "../fig/fig-2025-12-12-11-38-32.png"
  ),
  "8-10": (
    caption: [Transverse section of the wood of pine (Pinus). The wood is simple, consisting mostly of tracheids. Resin canals are present. Growth rings are visible (340).],
    path: "../fig/fig-2025-12-12-11-38-47.png"
  ),
  "8-11": (
    caption: [Transverse section of the wood of oak (Quercus). The wood is complex, with large vessels, small tracheids, fibers, and parenchyma. Large rays are present (340).],
    path: "../fig/fig-2025-12-12-11-39-04.png"
  ),
