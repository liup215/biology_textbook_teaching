#let images = (
  "15.1": (
    caption: [Interactions between environmental conditions and plant development, growth, energy production, and ion and nutrient balance and storage. The balance between these processes is controlled by the plant genome (bottom box), which encodes sensors and signal transduction pathways that monitor and adjust for environmental and internal inputs (open and dashed arrows). Based on the different environmental stress signals, the plant genome can thus direct the flow of energy between the different processes (solid arrows) to establish a new homeostatic state matched to the specific stress conditions.],
    path: "../fig/image_place_holder.png"
  ),
  "15.2": (
    caption: [Impact of abiotic stress on plant growth and reproduction. (A) Whereas moderate water-deficit stress does not have a significant effect on the growth of rice plants, severe water-deficit stress reduces growth. (B) Effect of salt stress on maize ear size. (C) Effect of salt stress on maize kernel size, demonstrating reduced crop yield under stress conditions.],
    path: "../fig/image_place_holder.png"
  ),
  "15.3": (
    caption: [Chemistry of reactive oxygen species (ROS). Molecular oxygen does not have any available unpaired electrons in its orbitals, but different forms of ROS have at least one unpaired electron. Various cellular metabolites can therefore transfer an electron to ROS and be oxidized in the process. The figure shows the chemical structures and electron configurations of superoxide radical, hydrogen peroxide, and hydroxyl radical.],
    path: "../fig/image_place_holder.png"
  ),
  "15.4": (
    caption: [Dual role of reactive oxygen species (ROS) during abiotic stress. A variety of abiotic stresses result in the accumulation of ROS in cells. On the one hand, ROS have a negative effect on plant growth, development, and yield by causing oxidative damage to cellular components. On the other hand, ROS accumulation has a positive effect on cells by activating signal transduction pathways that trigger stress acclimation responses and improve tolerance.],
    path: "../fig/image_place_holder.png"
  ),
  "15.5": (
    caption: [Effects of water stress on photosynthesis and leaf expansion of sunflower (Helianthus annuus). In this species, leaf expansion is completely inhibited under mild stress levels that barely affect photosynthetic rates, demonstrating that growth is more sensitive to water deficit than photosynthesis.],
    path: "../fig/image_place_holder.png"
  ),
  "15.6": (
    caption: [Effect of combined abiotic stresses on plant productivity, physiology, and molecular responses. (A) Losses to U.S. agriculture resulting from a combination of water-deficit stress and heat stress were much higher than losses caused by water-deficit stress, freezing, or flooding alone between 1980 and 2012. (B) Effect of combined stresses on plant physiological responses. (C) Molecular responses showing that stress combinations trigger unique gene expression patterns distinct from individual stresses.],
    path: "../fig/image_place_holder.png"
  ),
  "15.7": (
    caption: [Stress matrix. Different combinations of potential environmental stresses can have different effects on field crops. The matrix is color-coded to indicate stress combinations that were studied with different crops and their overall effect on plant growth and yield, demonstrating that multiple simultaneous stresses have complex interactive effects.],
    path: "../fig/image_place_holder.png"
  ),
  "15.8": (
    caption: [Early events in the sensing of abiotic stress by plants (blue boxes) and the signal transduction and acclimation pathways activated by these events (boxes with dashed borders). Various stress sensors detect changes in the environment, including mechanosensors, osmosensors, temperature sensors, and ROS sensors, which then activate downstream signaling cascades involving calcium, ROS, and hormones.],
    path: "../fig/image_place_holder.png"
  ),
  "15.9": (
    caption: [Stress-induced elevation of cellular Ca2+ can regulate transcription by various mechanisms. Elevated Ca2+ levels can result in Ca2+ binding to different proteins, including transcription factors (TF), various calmodulins (CaM), kinases (e.g., Ca2+-dependent protein kinases [CDPKs]) or kinase-binding proteins (e.g., calcineurin B-like [CBL] proteins). These Ca2+-binding proteins can then activate or phosphorylate different transcription factors to modulate gene expression during stress responses.],
    path: "../fig/image_place_holder.png"
  ),
  "15.10": (
    caption: [Basic ROS cycle. Normal metabolic reactions in cells, such as photosynthesis, respiration, photorespiration, and lipid oxidation, generate ROS. Various sensors monitor ROS levels in cells; an increase in ROS activates a signal transduction network that in turn activates ROS-scavenging mechanisms such as ascorbate peroxidase (APX), catalase (CAT), and superoxide dismutase (SOD). The signaling network also triggers acclimation responses that help cells adapt to stress conditions.],
    path: "../fig/image_place_holder.png"
  ),
  "15.11": (
    caption: [Interaction between ROS and Ca2+ signaling mediated by respiratory burst oxidase homolog (RBOH) proteins (NADPH oxidases), Ca2+-dependent protein kinases (CDPKs), and ROS-activated Ca2+ channels. ROS production by RBOH proteins is activated by elevated Ca2+ levels, and ROS in turn can activate Ca2+ channels, creating a positive feedback loop that amplifies both signals during stress responses.],
    path: "../fig/image_place_holder.png"
  ),
  "15.12": (
    caption: [Schematic diagram of mitogen-activated protein kinase (MAPK) cascades involved in plant signal transduction during abiotic stress responses. Upstream signals activate a MAPK kinase kinase (MAP3K), which phosphorylates and activates a MAPK kinase (MAP2K). The MAP2K then phosphorylates and activates a MAPK, which can phosphorylate various target proteins including transcription factors to regulate stress-responsive gene expression.],
    path: "../fig/image_place_holder.png"
  ),
  "15.13": (
    caption: [Example of two abiotic stress-activated signal transduction pathways that use four different types of regulons (transcription factor networks) to activate acclimation mechanisms. The regulons shown belong to the MYC/MYB, bZIP, DREB, and NAC families. For each regulon, the name of the DNA cis-element bound by the transcription factors is shown, demonstrating how different transcription factor families coordinate stress responses.],
    path: "../fig/image_place_holder.png"
  ),
  "15.14": (
    caption: [Rapid systemic signaling in response to local sensing of abiotic stress. (A) Schematic model of the ROS and Ca2+ waves that are required to mediate rapid systemic signaling in response to abiotic stress. The ROS wave is generated by an active, self-propagating wave of ROS production that starts at the initial tissue subjected to stress and spreads throughout the plant. (B) The Ca2+ wave follows the ROS wave and helps coordinate whole-plant stress responses.],
    path: "../fig/image_place_holder.png"
  ),
  "15.15": (
    caption: [Stress-induced changes in gene expression can be mediated by protein, lipid, or nucleic acid modification, second messengers, or hormones (e.g., abscisic acid, salicylic acid, jasmonic acid, and ethylene). Transcription changes or stress factors can affect chromatin via DNA methylation, histone tail modifications, histone variant replacement, and chromatin remodeling, leading to epigenetic regulation of stress-responsive genes.],
    path: "../fig/image_place_holder.png"
  ),
  "15.16": (
    caption: [Effects of water deficit on wild-type and transgenic tobacco plants expressing isopentenyl transferase (a key enzyme in the production of cytokinin) under the control of PSARK (Promoter region of Senescence-Associated Receptor Kinase), a maturation and stress-induced promoter. The transgenic plants show enhanced tolerance to water deficit, maintaining better growth and less wilting compared to wild-type plants.],
    path: "../fig/image_place_holder.png"
  ),
  "15.17": (
    caption: [Four groups of molecules frequently serve as compatible solutes: amino acids (such as proline), sugar alcohols (such as mannitol and sorbitol), quaternary ammonium compounds (such as glycine betaine), and tertiary sulfonium compounds (such as dimethylsulfoniopropionate). Note that these compounds are small, hydrophilic, and have no net charge, allowing them to accumulate to high concentrations without disrupting cellular functions while providing osmotic protection.],
    path: "../fig/image_place_holder.png"
  ),
  "15.18": (
    caption: [Scanning electron micrographs of transverse sections through roots of maize, showing changes in structure with O2 supply. (A) Control root, supplied with air, with intact cortical cells showing normal cellular architecture. (B) O2-deficient root growing in a stagnant solution, showing development of aerenchyma tissue with large air spaces formed by programmed cell death of cortical cells, which facilitates oxygen transport to submerged tissues.],
    path: "../fig/image_place_holder.png"
  ),
  "15.19": (
    caption: [Antioxidant biosynthetic pathways that regulate the levels of reactive oxygen species (ROS) in the cell. Superoxide dismutase converts superoxide radicals to hydrogen peroxide (H2O2), which is broken down to H2O and O2 by catalase. H2O2 can also be reduced to water by ascorbate peroxidase using ascorbate as an electron donor, which is then regenerated through the ascorbate-glutathione cycle involving dehydroascorbate reductase and glutathione reductase.],
    path: "../fig/image_place_holder.png"
  ),
  "15.20": (
    caption: [Molecular chaperone network in cells. Nascent proteins requiring the assistance of molecular chaperones to reach a proper conformation are associated with HSP70 chaperones (top). Native proteins that undergo denaturation during stress (denatured proteins; middle) associate with small heat shock proteins (sHSPs) to prevent aggregation. HSP70 and HSP90 chaperones, along with co-chaperones, help refold denatured proteins or target irreversibly damaged proteins for degradation via the ubiquitin-proteasome system.],
    path: "../fig/image_place_holder.png"
  ),
  "15.21": (
    caption: [Molecular structure of the metal chelate phytochelatin. Phytochelatin uses the sulfhydryl groups in cysteine residues to bind heavy metals such as cadmium, zinc, and arsenic. The general structure is (γ-Glu-Cys)n-Gly, where n typically ranges from 2 to 11, providing multiple metal-binding sites for detoxification of toxic heavy metals.],
    path: "../fig/image_place_holder.png"
  ),
  "15.22": (
    caption: [Changes in leaf water potential, stomatal resistance (the inverse of stomatal conductance), and ABA content in maize in response to water stress. As the soil dries out, the water potential of the leaf decreases, and the ABA content and stomatal resistance increase in a coordinated manner. Re-watering reverses the process, demonstrating the tight coupling between water status, ABA levels, and stomatal behavior.],
    path: "../fig/image_place_holder.png"
  ),
  "15.23": (
    caption: [Time course of the ABA-induced increase in guard cell cytosolic Ca2+ concentration (upper panel) and ABA-induced stomatal closure (lower panel). The rise in Ca2+ begins within approximately 3 min of the addition of ABA, followed by a steady decrease in the size of the stomatal aperture within an additional 5 min, demonstrating the rapid signaling cascade from ABA perception to stomatal response.],
    path: "../fig/image_place_holder.png"
  ),
  "15.24": (
    caption: [Simplified model for ABA signaling in stomatal guard cells. ABA binds to PYR/PYL/RCAR receptors, which then inhibit PP2C phosphatases, allowing activation of OST1 and CPK kinases. The net effect is the activation of anion channels and inhibition of inward K+ channels, leading to loss of potassium (K+) and its counter anions (Cl– or malate2–) from the cell, causing water efflux and stomatal closure.],
    path: "../fig/image_place_holder.png"
  ),
  "15.25": (
    caption: [Morphological changes in response to abiotic stress. (A) Altered leaf shape can occur in response to environmental changes. The oak (Quercus sp.) leaf on the left is from the outside of a tree canopy, where temperatures are higher than they are inside the canopy. The leaf on the right is from the inside of the canopy. The deeper sinuses of the outer leaf increase air circulation and evaporative cooling. (B) Sun and shade leaves of the same species show different morphologies adapted to their light environments.],
    path: "../fig/image_place_holder.png"
  ),
  "15.26": (
    caption: [Effect of water-deficit conditions on root and shoot growth of fox millet (Panicum italicum L.) seedlings. The soil moisture was maintained at 80 to 90% of field capacity in well-watered (control) conditions and at 50% in water-deficit stress conditions. Under water deficit, root growth is maintained or even enhanced while shoot growth is reduced, demonstrating differential sensitivity of organs to water stress and adaptive allocation of resources.],
    path: "../fig/image_place_holder.png"
  ),
  "15.27": (
    caption: [Under water-deficit stress conditions (low Ψ, defined slightly differently for shoot and root), the ratio of root growth to shoot growth is much higher when ABA is present (i.e., in the wild type) than when it is absent (in the ABA-deficient mutant). This demonstrates that ABA is required for the adaptive change in root-to-shoot biomass ratio in response to water-deficit stress, allowing plants to prioritize root growth for water acquisition.],
    path: "../fig/image_place_holder.png"
  ),
  "table-15.1": (
    caption: [Physiological and biochemical perturbations in plants caused by fluctuations in the abiotic environment. This comprehensive table lists various environmental factors (water deficit, salinity, flooding/oxygen deprivation, heat, cold/chilling, freezing, and high light/UV) and describes their primary physiological and biochemical effects on plants, including impacts on photosynthesis, respiration, membrane integrity, enzyme function, and metabolic processes.],
    path: "../fig/image_place_holder.png"
  ),
  "table-15.2": (
    caption: [Reactive oxygen species (ROS) and their properties. The table lists different ROS molecules including singlet oxygen, superoxide radical, hydrogen peroxide, and hydroxyl radical, along with their chemical abbreviations, sources of production in plant cells, and relative reactivity/half-life. It illustrates that different ROS have varying levels of reactivity and lifetimes, affecting their roles as damaging agents versus signaling molecules.],
    path: "../fig/image_place_holder.png"
  ),
  "table-15.3": (
    caption: [Fatty acid composition of mitochondria isolated from chilling-resistant and chilling-sensitive species. The table shows percent weight of total fatty acid content in mitochondrial membranes, demonstrating that chilling-resistant species have higher proportions of unsaturated fatty acids (especially linoleic and linolenic acids) compared to chilling-sensitive species, which helps maintain membrane fluidity at low temperatures.],
    path: "../fig/image_place_holder.png"
  ),
)
