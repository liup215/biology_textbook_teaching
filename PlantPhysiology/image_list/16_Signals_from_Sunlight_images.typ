#let images = (
  "16.1": (
    caption: [Sunlight exerts multiple influences on plants. Plants expose their leaves to sunlight to transform solar energy into chemical energy, and they also use sunlight for a wide range of developmental signals that optimize photosynthesis and detect seasonal changes. This figure illustrates how plants integrate light signals for both energy capture through photosynthesis and developmental regulation through photoreceptor systems.],
    path: "../fig/image_place_holder.png"
  ),
  "16.2": (
    caption: [Comparison of seedlings grown in the light versus the dark. Left shows cress seedlings grown in the light with normal development. Right shows cress seedlings grown in the dark exhibiting etiolation, characterized by elongated hypocotyls and a lack of chlorophyll. This demonstrates the dramatic effect of light on plant morphology through photomorphogenesis.],
    path: "../fig/image_place_holder.png"
  ),
  "16.3": (
    caption: [Time-lapse photograph of a maize (corn) coleoptile bending toward unilateral blue light, demonstrating phototropism. The series shows how the growing shoot tip curves toward the light source over time. This directional growth response is mediated by phototropin photoreceptors and involves differential cell elongation on the shaded versus illuminated sides.],
    path: "../fig/image_place_holder.png"
  ),
  "16.4": (
    caption: [Plants can use visible light, UV-A, and UV-B radiation as developmental signals. The spectrum shows different wavelength ranges (in nm) and their biological significance. Red light (600-700 nm) and far-red light (700-750 nm) are sensed by phytochromes, blue light (400-500 nm) by cryptochromes and phototropins, and UV-B (280-320 nm) by UVR8. This spectral sensitivity allows plants to detect and respond to their light environment comprehensively.],
    path: "../fig/image_place_holder.png"
  ),
  "16.5": (
    caption: [Lettuce seed germination is a typical photoreversible response controlled by phytochrome. Red light promotes lettuce seed germination, but this effect is reversed by far-red light. Imbibed seeds given the last treatment with red light germinate, while those given far-red light as the final treatment do not. This demonstrates the photoreversibility characteristic of phytochrome-mediated responses and the Pr/Pfr equilibrium.],
    path: "../fig/image_place_holder.png"
  ),
  "16.6": (
    caption: [The action spectrum of phytochrome function matches its absorption spectrum. (A) Action spectra for the photoreversible stimulation and inhibition of seed germination in Arabidopsis, showing peaks in red and far-red regions. (B) Absorption spectra of purified oat phytochrome in the Pr (red absorbing) and Pfr (far-red absorbing) forms. The overlap between action and absorption spectra confirms phytochrome as the photoreceptor for these responses.],
    path: "../fig/image_place_holder.png"
  ),
  "16.7": (
    caption: [The action spectrum of phototropism matches the absorption spectrum of the light-sensing domain of phototropin. (A) Action spectrum for blue light-stimulated phototropism in alfalfa hypocotyls, showing characteristic three-finger pattern in the 400-500 nm region. (B) Absorption spectrum of the LOV domain of phototropin. The close match between action and absorption spectra identifies phototropin as the photoreceptor for phototropism.],
    path: "../fig/image_place_holder.png"
  ),
  "16.8": (
    caption: [Structure of the Pr and Pfr forms of the tetrapyrrole chromophore phytochromobilin and the peptide region bound to the chromophore through a thioether linkage. The chromophore undergoes a cis-trans isomerization at carbon 15 in response to red and far-red light. This conformational change in the chromophore triggers the protein conformational changes that activate phytochrome signaling.],
    path: "../fig/image_place_holder.png"
  ),
  "16.9": (
    caption: [Phytochrome domains and their functions. (A) Schematic representation of plant phytochrome (PHY), prokaryotic Cph1 (cyanobacterial phytochrome 1), and BphP (bacterial phytochrome-like protein). The chromophore is attached to cysteine residues via a thioether link. (B) Crystal structure of Arabidopsis phyB showing the photosensory module. The N-terminal half contains PAS and GAF domains that bind the chromophore, while the C-terminal region contains PHY and PAS domains involved in dimerization and signaling.],
    path: "../fig/image_place_holder.png"
  ),
  "16.10": (
    caption: [Steps in phytochrome activation and signal transduction in photomorphogenesis. After synthesis of phytochromobilin in the plastid and assembly with the apoprotein (1), phytochrome is activated by red light (2) and moves into the nucleus (3) to modulate gene expression. A small pool of phytochrome remains in the cytosol. In the nucleus, Pfr interacts with transcription factors to regulate photomorphogenic development.],
    path: "../fig/image_place_holder.png"
  ),
  "16.11": (
    caption: [Nuclear localization of phytochrome-GFP fusion proteins in epidermal cells of Arabidopsis hypocotyls observed under fluorescence microscopy. Only nuclei are visible, demonstrating that light treatments induced nuclear accumulation of the phytochrome-GFP fusion proteins. In darkness, phytochrome is absent from the nucleus. These results indicate a role for nuclear localization in phytochrome signal transduction.],
    path: "../fig/image_place_holder.png"
  ),
  "16.12": (
    caption: [Three types of phytochrome responses based on their sensitivities to fluence. The relative magnitudes of representative responses are plotted against increasing fluences of red light. Short light pulses activate very low fluence responses (VLFRs) and low-fluence responses (LFRs). The fluence at which LFRs are initiated varies with species. High-irradiance responses (HIRs) are proportional to irradiance as well as fluence, shown here at three different irradiances given continuously.],
    path: "../fig/image_place_holder.png"
  ),
  "16.13": (
    caption: [Phytochrome interacting factors (PIFs) act as negative regulators of photomorphogenesis. (A) Most PIFs are constitutive activators of genes expressed in the dark or in response to shade. In the light, Pfr promotes degradation of the PIFs, blocking transcription of skotomorphogenesis genes. (B) During de-etiolation, PIFs also act as constitutive repressors of some light-induced genes by binding to G-Box motifs (CACGTG) or PIF Binding Elements (CACATG) collectively called PBE-box elements.],
    path: "../fig/image_place_holder.png"
  ),
  "16.14": (
    caption: [COP proteins regulate the turnover of proteins required for photomorphogenic development. During the night, COP1 enters the nucleus with help from the COP9 signalosome complex (CSN). COP1 forms a complex with SUPPRESSOR OF PHYTOCHROME A1 (SPA1), and the COP1-SPA1 complex adds ubiquitin to phytochrome-responsive transcription factors that promote photomorphogenesis. During the day, COP1 is excluded from the nucleus, allowing transcription factors to accumulate.],
    path: "../fig/image_place_holder.png"
  ),
  "16.15": (
    caption: [Blue light reduces hypocotyl elongation after rapid membrane depolarization. (A) Blue light-induced changes in elongation rates of etiolated cucumber hypocotyls, showing rapid inhibition within seconds. (B) Blue light-induced transient membrane depolarization of hypocotyl cells. These rapid responses demonstrate the speed of blue light signal transduction through phototropin activation.],
    path: "../fig/image_place_holder.png"
  ),
  "16.16": (
    caption: [Cryptochrome domain and chromophore structure. (A) Alignment of two cryptochromes from Arabidopsis showing the photolyase-homology region (PHR) with the FAD-binding domain and the cryptochrome C-terminal (CCT) extension. (B) Cryptochrome monomer ribbon diagram showing the light-harvesting cofactor MTHF and the catalytic cofactor FAD noncovalently bound to the protein. (C) The structures of FAD and the pterin cofactor MTHF.],
    path: "../fig/image_place_holder.png"
  ),
  "16.17": (
    caption: [Blue light stimulates the accumulation of anthocyanins (A) and the inhibition of stem elongation (B) in transgenic and mutant seedlings of Arabidopsis. Bar graphs show phenotypes of a transgenic plant overexpressing CRY1 (CRY1 OE), wild type (WT), and cry1 loss-of-function mutants. The enhanced blue-light response of the CRY1 overexpressor demonstrates the important role of this gene product in stimulating anthocyanin biosynthesis and inhibiting stem elongation.],
    path: "../fig/image_place_holder.png"
  ),
  "16.18": (
    caption: [Model of cry1 interactions with COP1 and SPA1 in the regulation of photomorphogenesis. In darkness, COP1 and SPA1 form a complex that ubiquitinates and degrades photomorphogenic transcription factors like HY5. Upon blue light activation, cry1 forms a complex with COP1 and SPA1 via its C-terminal domain, preventing them from degrading protein targets and allowing photomorphogenesis to proceed.],
    path: "../fig/image_place_holder.png"
  ),
  "16.19": (
    caption: [Sensory transduction process of blue light-stimulated inhibition of stem elongation in wild-type Arabidopsis. Elongation rates in the dark (0.25 mm/h) were normalized to 1. Within 30 seconds of blue light irradiation, growth rates decreased and approached zero within 30 minutes. In a phot1 mutant, dark growth rates remained unchanged for the first 30 minutes, indicating that phototropin 1 mediates the rapid inhibition of elongation.],
    path: "../fig/image_place_holder.png"
  ),
  "16.20": (
    caption: [Phototropin domain composition, photocycle, and LOV domain structure. (A) Domain compositions of phototropin and related LOV-domain photoreceptors, showing two LOV domains and a serine/threonine kinase domain. (B) The FMN photocycle of phototropin: in darkness, FMN absorbs at 450 nm; blue light induces formation of a covalent bond between FMN and cysteine, shifting absorption to 390 nm. (C) Structure of the LOV2 domain showing FMN chromophore and the Jα helix that regulates kinase activity.],
    path: "../fig/image_place_holder.png"
  ),
  "16.21": (
    caption: [Phototropism in Arabidopsis seedlings used as bioassay for phototropin activity. (A) Wild type with both LOV1 and LOV2 domains shows normal phototropism. (B) Mutating the cysteine in the LOV1 domain of phot1 does not affect phototropic responsiveness. (C) The equivalent mutation in the LOV2 domain abolishes the response, demonstrating that only the LOV2 domain is required for phototropism.],
    path: "../fig/image_place_holder.png"
  ),
  "16.22": (
    caption: [Model for blue light-induced autophosphorylation of phototropin. Phototropin has two LOV domains (yellow) and a kinase domain (red), separated by an α-helical Jα region. In the absence of light, the N-terminal region including the LOV domains cages and represses the kinase domain activity. Upon blue light absorption, the LOV2 domain undergoes conformational changes that release the Jα helix, allowing kinase domain activation and autophosphorylation.],
    path: "../fig/image_place_holder.png"
  ),
  "16.23": (
    caption: [Schematic diagram of chloroplast distribution patterns in Arabidopsis palisade cells in response to different light intensities. (A) Under low light conditions, chloroplasts optimize light absorption by accumulating at the adaxial and abaxial sides of palisade cells (accumulation response). (B) Under high light conditions, chloroplasts avoid sunlight by migrating to the side walls (avoidance response). (C) Chloroplasts move to the bottom of the cell in darkness.],
    path: "../fig/image_place_holder.png"
  ),
  "16.24": (
    caption: [Model for phototropin-mediated chloroplast movement in Arabidopsis thaliana. Both phot1 and phot2 mediate the accumulation response and are localized at the plasma membrane. phot2 is also localized on the chloroplast envelope and mediates the avoidance response. CHUP1 binds to the chloroplast envelope and may anchor to the plasma membrane, initiating profilin-mediated actin polymerization to extend F-actin filaments that guide chloroplast movement.],
    path: "../fig/image_place_holder.png"
  ),
  "16.25": (
    caption: [Role of the proton-pumping ATPase in the regulation of stomatal movement. Blue light activates the H+-ATPase through phosphorylation of serine and threonine residues of its C-terminal domain. A regulatory 14-3-3 protein binds to the phosphorylated C terminus. Pumping protons out of the cell increases K+ entry to balance the charge, leading to water uptake and stomatal opening.],
    path: "../fig/image_place_holder.png"
  ),
  "16.26": (
    caption: [Phototropin signal transduction leading to stomatal opening. Blue light activates phototropin, which phosphorylates BLUS1. This leads to activation of the plasma membrane H+-ATPase through 14-3-3 protein binding. H+ pumping causes membrane hyperpolarization, allowing K+ and anion channel opening. Accumulation of K+, Cl-, and malate increases osmotic potential, driving water uptake, vacuolar expansion, turgor increase, and ultimately stomatal opening.],
    path: "../fig/image_place_holder.png"
  ),
  "16.27": (
    caption: [UVR8 structure and dimerization. (A) End-on view showing the seven blades of the β-propeller structure of UVR8. (B) Side view of the UVR8 dimer showing amino acid residues at the interaction surface. UV-B absorption causes monomerization of the dimer. The monomers interact with COP1 to initiate UV-B signaling. RUP proteins facilitate redimerization to regenerate the photoreceptor.],
    path: "../fig/image_place_holder.png"
  ),
  "16.28": (
    caption: [The UVR8 signaling pathway involves COP1 and SPA1. UV-B causes UVR8 dimer dissociation into monomers. UVR8 monomers interact with COP1 and SPA1, sequestering them and preventing degradation of transcription factors. The active complex regulates transcription of genes involved in UV-B response, including RUP proteins. RUP proteins facilitate redimerization of UVR8 monomers, inactivating them and completing the cycle.],
    path: "../fig/image_place_holder.png"
  ),
  "table-16.1": (
    caption: [Ecologically important light parameters affecting plants. This table presents different light conditions (daylight, moonlight, starlight, canopy shade) and their characteristics including photon flux density, wavelength distribution, and biological significance. Understanding these parameters helps explain how plants have evolved different photoreceptor systems to respond to various light environments.],
    path: "../fig/image_place_holder.png"
  ),
  "table-16.2": (
    caption: [Typical photoreversible responses induced by phytochrome in a variety of plant species. Lists various physiological and developmental responses that are activated by red light and reversed by far-red light, including seed germination, stem elongation inhibition, leaf expansion, chloroplast development, enzyme synthesis, and flowering. These responses demonstrate the wide-ranging effects of phytochrome signaling across plant development.],
    path: "../fig/image_place_holder.png"
  ),
  "table-16.3": (
    caption: [Some plant photomorphogenic responses induced by continuous irradiation. Shows high-irradiance responses (HIRs) that require prolonged or continuous light exposure, including stem elongation inhibition, anthocyanin synthesis, and chloroplast development. These responses are proportional to both fluence and irradiance and are mediated by different phytochrome types depending on wavelength.],
    path: "../fig/image_place_holder.png"
  ),
  "table-16.4": (
    caption: [Photomorphogenic responses mediated by blue light photoreceptors. Lists various blue light responses including phototropism, stomatal opening, chloroplast movement, inhibition of stem elongation, and regulation of gene expression. Indicates whether responses are mediated by phototropins, cryptochromes, or both, demonstrating the specificity and overlap of blue light photoreceptor functions.],
    path: "../fig/image_place_holder.png"
  ),
)
