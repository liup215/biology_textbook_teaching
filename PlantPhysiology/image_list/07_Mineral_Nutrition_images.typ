#let images = (
  "box-7.1-figure-a": (
    caption: [World trends in human population, nitrogen fertilizer consumption, nitrogen oxide emissions, carbon dioxide emissions, and total anthropogenic reactive nitrogen production from 1900 to 2020. The graph demonstrates the dramatic increase in all parameters since 1940, with the rate of human nitrogen fixation now approximately twice that of biological nitrogen fixation in terrestrial ecosystems. This highlights the significant impact of synthetic fertilizer production on the global nitrogen cycle and its relationship to population growth and environmental change.],
    path: "../fig/image_place_holder.png"
