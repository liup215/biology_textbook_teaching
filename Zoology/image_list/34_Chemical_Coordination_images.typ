  "figure-34-9": (
    caption: [Effect of thyroid hormones (T3 and T4) on growth and metamorphosis of a frog. The release of TRH from the hypothalamus at the end of premetamorphosis sets in motion hormonal changes (increased TSH, T3 and T4) leading to metamorphosis. Thyroid hormone levels are maximal at the time forelimbs emerge.],
    path: "../fig/fig-2025-12-03-16-23-47.png"
  ),
  "figure-34-10": (
    caption: [A large goiter caused by iodine deficiency. Overstimulation by excess TSH causes the gland to enlarge enormously, as the thyroid gland is stimulated to extract enough iodine from the blood to synthesize the body’s requirement for thyroid hormones.],
    path: "../fig/fig-2025-12-03-16-24-03.png"
