#let images = (
  "figure-21-1": (
    caption: [Cladogram showing hypothetical relationships among hexapods. Many synapomorphies have been omitted. Orders Protura, Collembola, and Diplura are entognathous. These orders, plus Thysanura, originated before the earliest winged ancestors. Orders Odonata and Ephemeroptera form Paleoptera, where wings are outspread. The remaining orders have wings that can fold back over the abdomen (Neoptera).],
    path: "../fig/fig-2025-12-01-15-50-22.png"
  ),
