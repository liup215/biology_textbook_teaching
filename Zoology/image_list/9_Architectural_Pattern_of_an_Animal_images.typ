  ),
  "figure-9-8": (
    caption: [Types of simple epithelium. A: Simple squamous (flattened cells, diffusion/transport). B: Simple cuboidal (boxlike cells, secretion/absorption). C: Simple columnar (tall cells, absorption, often with microvilli).],
    path: "../fig/fig-2025-11-19-16-55-17.png"
  ),
  "figure-9-9": (
    caption: [Types of stratified epithelium. Stratified squamous: many layers, withstands abrasion (e.g., oral cavity, esophagus). Transitional: specialized for stretching (e.g., urinary bladder).],
    path: "../fig/fig-2025-11-19-16-56-25.png"
  ),
