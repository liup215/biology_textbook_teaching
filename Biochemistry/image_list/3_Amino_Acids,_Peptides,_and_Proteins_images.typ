  "3-30": (
    caption: [Electrospray ionization mass spectrometry of a protein. (a) A protein solution is dispersed into highly charged droplets. (b) The spectrum generated is a family of peaks, with each successive peak corresponding to a charged species increased by 1 in both mass and charge.],
    path: "../fig/fig-2025-09-25-01-05-14.png"
  ),
  "3-31": (
    caption: [Obtaining protein sequence information with tandem MS. (a) After proteolytic hydrolysis, a protein solution is injected into a mass spectrometer (MS-1). (b) A typical spectrum with peaks representing the peptide fragments generated from a sample of one small peptide (21 residues).],
    path: "../fig/fig-2025-09-25-01-05-48.png"
  ),
  "3-32": (
